{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "eqeqeq": "error",
    "no-console": "off"
  },
  "ignorePatterns": ["dist/**", "node_modules/**", ".turbo/**", ".wrangler/**", "bin/**"]
}
